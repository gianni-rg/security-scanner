# Auto-detect text files, ensure they use LF.
* text=auto eol=lf working-tree-encoding=UTF-8

# Shell scripts should always use LF line endings
*.sh text eol=lf
# Batch scripts should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
# Docker-related files should use LF
Dockerfile text eol=lf
docker-compose.yml text eol=lf
*.dockerfile text eol=lf
# Configuration files
*.conf text eol=lf
*.template text eol=lf
# JavaScript/Node files
*.js text eol=lf
*.json text eol=lf
*.jsx text eol=lf
# CSS files
*.css text eol=lf
# Markdown
*.md text eol=lf
