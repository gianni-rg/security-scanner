# =============================================================================
# Security Scanner Environment Configuration (Example)
# =============================================================================
# Copy this file to .env and fill in the values
# Copy-Item .env.example .env
# =============================================================================

# Directories to skip during scanning (comma-separated)
SKIP_DIRS=node_modules,vendor,.terraform,dist,build,target,.venv,venv,__pycache__,.gradle,Pods

# Severity levels that cause workflow failure
FAIL_ON_SEVERITY=CRITICAL,HIGH

# Allow scans to run as root if the runtime cannot drop privileges inside the container
ALLOW_ROOT_FALLBACK=false

# License identifiers that should fail the license scan
FORBIDDEN_LICENSES=GPL-3.0,AGPL-3.0

# Hadolint levels that should fail the scan
HADOLINT_FAIL_ON=error

# Optional comma-separated Hadolint rule IDs to ignore
HADOLINT_IGNORED_RULES=

# Minimum ShellCheck severity to include in findings (error, warning, info, style)
SHELLCHECK_SEVERITY=warning

# yamllint levels that should fail the scan
YAMLLINT_FAIL_ON=error,warning

# Optional container image reference for the trivy-image command
IMAGE_REF=
